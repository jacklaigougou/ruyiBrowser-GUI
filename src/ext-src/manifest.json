{
  "manifest_version": 2,
  "name": "ruyi-proxy",
  "version": "1.0",
  "description": "SOCKS5 proxy injector for ruyiBrowser",
  "permissions": ["proxy", "storage", "<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ruyi-proxy@ruyipage.local"
    }
  }
}
