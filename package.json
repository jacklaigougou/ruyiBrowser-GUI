{
  "name": "ruyipage-electron",
  "version": "1.0.0",
  "description": "ruyiPage 图形化管理工具 - 基于Electron的ruyipage GUI封装",
  "main": "src/main/main.js",
  "scripts": {
    "dev:vite": "vite src/renderer",
    "dev": "concurrently \"npm run dev:vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build:renderer": "vite build src/renderer",
    "build": "npm run build:renderer && electron-builder",
    "preview": "vite preview src/renderer"
  },
  "keywords": [
    "electron",
    "ruyipage",
    "firefox",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^8.0.10",
    "vue-router": "^5.0.6",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "vue": "^3.5.33"
  },
  "build": {
    "appId": "com.ruyipage.electron",
    "productName": "ruyiPage GUI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ]
  }
}
