{
  "name": "ruyipage-electron",
  "version": "1.0.0",
  "description": "ruyiPage 图形化管理工具 - 基于Electron的ruyipage GUI封装",
  "main": "src/main/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev": "concurrently \"npm run dev:vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "preview": "vite preview src/renderer",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [
    "electron",
    "ruyipage",
    "firefox",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^3.0.1",
    "vite": "^8.0.10",
    "vue-router": "^5.0.6",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "node-fetch": "^3.3.2",
    "vue": "^3.5.33"
  },
  "build": {
    "appId": "com.ruyipage.electron",
    "productName": "ruyiPage GUI",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*",
          "!.venv/**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ]
  }
}
